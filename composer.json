{
    "name": "panchodp/laravel-fingerprint",
    "description": "Laravel Session theft protection via client fingerprinting \u2014 auto-invalidates sessions used from unrecognized devices.",
    "keywords": [
        "php",
        "laravel",
        "fingerprint",
        "security"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Francisco De Pablo",
            "email": "fcodepablo@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.0",
        "rector/rector": "^2.0",
        "larastan/larastan": "^3.9.3",
        "orchestra/testbench": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Panchodp\\LaravelFingerprint\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panchodp\\LaravelFingerprint\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "pint": "vendor/bin/pint",
        "analyze": "vendor/bin/phpstan analyse src tests",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:all": [
            "@test",
            "@pint",
            "@analyze"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Panchodp\\LaravelFingerprint\\LaravelFingerprintServiceProvider"
            ],
            "aliases": {}
        }
    }
}
